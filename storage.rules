rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // genome-browser 폴더: 모든 사용자 읽기 허용
    match /genome-browser/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // 기타 파일: 읽기 공개, 쓰기는 인증 필요
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
